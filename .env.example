# ══════════════════════════════════════════════════════════════════════════════
# CCTI Service Desk — Variáveis de ambiente
# Copie para .env e preencha os valores antes de subir em produção
# ══════════════════════════════════════════════════════════════════════════════

# ── Segurança ──────────────────────────────────────────────────────────────────
# OBRIGATÓRIO — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=coloque-aqui-uma-chave-secreta-longa

# Ambiente: development | production
FLASK_ENV=production

# ── Admin padrão (criado na 1ª execução) ──────────────────────────────────────
ADMIN_DEFAULT_EMAIL=admin@suaempresa.com
ADMIN_DEFAULT_PASSWORD=troque-esta-senha

# ── E-mail / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=chamados@suaempresa.com
SMTP_PASS=senha-do-email
SMTP_FROM=chamados@suaempresa.com
# Destinatários do digest diário (separados por vírgula)
ALERT_TO_EMAILS=admin@suaempresa.com,ti@suaempresa.com

# ── Monitoramento de erros ─────────────────────────────────────────────────────
# Obtenha grátis em https://sentry.io  — deixe vazio para desativar
SENTRY_DSN=

# ── URL pública (usada em e-mails e portal externo) ────────────────────────────
APP_URL=https://chamados.suaempresa.com

# ── Backup automático ─────────────────────────────────────────────────────────
BACKUP_DIR=instance/backups
BACKUP_KEEP_DAYS=30


# IA assistida
AI_ASSIST_ENABLED=false
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL=gemini-1.5-flash
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_TIMEOUT_SECONDS=30
AI_MAX_CONTEXT_CHARS=6000


# Fila / assunção com timeout
ASSIGNMENT_AUTO_FALLBACK_ENABLED=true
ASSIGNMENT_TIMEOUT_MINUTES=15

# NF / rascunhos
NF_CANCELLED_DRAFT_RETENTION_DAYS=15
NF_DRAFT_MAX_AGE_DAYS=30

# Reabertura de chamados
TICKET_REOPEN_WINDOW_HOURS=48

# Sessão (expiração por inatividade)
SESSION_LIFETIME_HOURS=8

# CSRF (desativar apenas em desenvolvimento)
WTF_CSRF_ENABLED=true
