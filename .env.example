# Segurança
SECRET_KEY=mude-esta-chave-em-producao

# Credenciais padrão do admin (criadas automaticamente na 1ª execução)
ADMIN_DEFAULT_EMAIL=admin@suaempresa.com
ADMIN_DEFAULT_PASSWORD=admin123

# SMTP — notificações por e-mail (deixe em branco para desabilitar)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua-senha-de-app-google
SMTP_FROM=chamados@suaempresa.com

# E-mails que recebem alertas de novos chamados (separados por vírgula)
ALERT_TO_EMAILS=equipe@suaempresa.com,gestor@suaempresa.com
